# Normalize text files
* text=auto

# HDL / FPGA source files should stay LF for stable diffs
*.sv  text eol=lf
*.v   text eol=lf
*.vh  text eol=lf
*.xdc text eol=lf
*.tcl text eol=lf
*.xci text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# PowerShell scripts are usually edited on Windows
*.ps1 text eol=crlf

# Binary / generated-style files
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
